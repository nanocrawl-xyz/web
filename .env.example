# ── Mock Crawler / Test Buyer (for scripts/test-crawler.ts) ──────────────
# A SEPARATE wallet from the seller — fund at https://faucet.circle.com
# then deposit USDC into Circle Gateway before running npm run crawl
NANOCRAWL_BUYER_PRIVATE_KEY=your_buyer_private_key_here
NANOCRAWL_BUYER_WALLET=0xYourBuyerAddressHere

# ── Merchant (Seller) ─────────────────────────────────────────────────────
# EVM private key for the merchant wallet (no 0x prefix)
NANOCRAWL_SELLER_PRIVATE_KEY=your_merchant_private_key_here

# EVM address corresponding to the private key above
NANOCRAWL_SELLER_WALLET=0xYourMerchantAddressHere

# ── Pricing ───────────────────────────────────────────────────────────────
# Default price per page in USDC (e.g. 0.001 = $0.001)
NANOCRAWL_DEFAULT_PRICE_USDC=0.001

# ── Network ───────────────────────────────────────────────────────────────
# Arc Testnet — do not change for hackathon demo
NANOCRAWL_NETWORK=eip155:5042002

# ── App ───────────────────────────────────────────────────────────────────
# Public URL of this deployment (used in robots.txt Payment-Endpoint field)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
